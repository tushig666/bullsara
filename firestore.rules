/**
 * Core Philosophy:
 * This ruleset implements a hybrid security model tailored for an e-commerce application.
 * It combines strict user-ownership for personal data (orders), role-based
 * access control for administrative functions (managing products), and public read
 * access for shared data (active products).
 *
 * Data Structure:
 * User-specific data (orders) are stored in subcollections under `/users/{userId}`.
 * This path-based ownership allows for simple and secure rules. A dedicated `/roles_admin` 
 * collection serves as an efficient, non-hierarchical lookup table for identifying administrators.
 *
 * Key Security Decisions:
 * 1. Admin Checks: Administrator privileges are verified using an `exists()` check against
 *    the `/roles_admin/{userId}` collection. This is significantly more performant
 *    and secure than reading a 'role' field from a user profile.
 * 2. Path-Based Security for Reads: For user-specific data in subcollections
 *    (e.g., `/users/{userId}/orders`), rules can simply check if the requester's UID
 *    matches the `{userId}` in the path, ensuring users can only access their own data.
 * 3. Collection Group Queries: Rules are in place to allow administrators to perform
 *    collection group queries across all `orders` for administrative purposes.
 * 4. Write Operations: All write operations (`create`, `update`, `delete`) are
 *    strictly controlled. Users can create their own orders, but only admins can
 *    modify them.
 * 5. Listing Prohibition: Listing all users from the `/users` collection is explicitly
 *    disallowed to protect user privacy and prevent data scraping.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    function isCreatingOwnContent(userId) {
      return request.resource.data.userId == userId;
    }
    
    function isUserIdImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false; // Disallow listing all users to protect privacy.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) || isAdmin();

      match /orders/{orderId} {
        // Owner can create and read their own orders.
        // Admins can read any order.
        allow read, create: if isOwner(userId) || isAdmin();
        // Only admins can update an order's status (e.g., 'paid') or delete it.
        allow update, delete: if isAdmin();
      }
    }

    // This collection group query is used by admins to list all orders.
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }
    
    match /roles_admin/{userId} {
      // DEV-ONLY: Allow a user to make themselves an admin for development purposes.
      // In production, this should be 'if false' and managed by a trusted server process.
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /products/{productId} {
      allow get: if isAdmin();
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
