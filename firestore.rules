/**
 * Core Philosophy:
 * This ruleset implements a hybrid security model tailored for a lottery application.
 * It combines strict user-ownership for personal data (orders, tickets), role-based
 * access control for administrative functions (managing lotteries), and public read
 * access for shared data (active lotteries).
 *
 * Data Structure:
 * All data is in top-level collections. Ownership is enforced via a 'userId' field
 * on relevant documents, which is checked against the authenticated user's UID.
 * A dedicated `/roles_admin` collection serves as an efficient, non-hierarchical 
 * lookup table for identifying administrators.
 *
 * Key Security Decisions:
 * 1. Admin Checks: Administrator privileges are verified using an `exists()` check against
 *    the `/roles_admin/{userId}` collection. This is significantly more performant
 *    and secure than reading a 'role' field from a user profile.
 * 2. Query-Based Security for Lists: To protect user privacy, `list` operations on 
 *    user-owned collections (`orders`, `tickets`) are only allowed if the query
 *    explicitly filters by the current user's `userId`. This enforces that users can only see their own data.
 * 3. Denormalization for Authorization: The `userId` of an
 *    order's owner is copied directly into the corresponding `/payments/{paymentId}`
 *    document. This allows payment rules to authorize access directly.
 * 4. Write Operations: All write operations (`create`, `update`, `delete`) are
 *    strictly controlled. There are no open writes; every modification requires
 *    proof of ownership or administrative privilege.
 * 5. Listing Prohibition: Listing all users from the `/users` collection is explicitly
 *    disallowed to protect user privacy and prevent data scraping.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isExistingDoc() {
      return resource != null;
    }
    
    function isCreatingOwnContent(userId) {
      return request.resource.data.userId == userId;
    }
    
    function isUserIdImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false; // Disallow listing all users to protect privacy.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /roles_admin/{userId} {
      allow read, write: if false; // Must be managed by a trusted server process.
    }

    match /lotteries/{lotteryId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }

    match /orders/{orderId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if (isSignedIn() && request.query.where.userId == request.auth.uid) || isAdmin();
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isAdmin(); // Status updates are admin-only actions
      allow delete: if isAdmin();
    }

    match /tickets/{ticketId} {
        allow get: if isOwner(resource.data.userId) || isAdmin();
        allow list: if (isSignedIn() && request.query.where.userId == request.auth.uid) || isAdmin();
        allow create: if isAdmin(); // Tickets are created by admins confirming payment
        allow update: if isAdmin();
        allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      // NOTE: The 'userId' field MUST be denormalized onto this document from the associated Order for these rules to work.
      allow get: if (isOwner(resource.data.userId) || isAdmin()) && isExistingDoc();
      // Allow listing ONLY when the query explicitly filters for the user's own payments.
      allow list: if (isSignedIn() && request.query.where.userId == request.auth.uid) || isAdmin();
      allow create: if isOwner(request.resource.data.userId); // Assumes a client (or function) can create a payment record for themselves.
      allow update: if (isOwner(resource.data.userId) || isAdmin()) && isExistingDoc() && isUserIdImmutable();
      allow delete: if false; // Payments should generally not be deletable by clients.
    }
  }
}
