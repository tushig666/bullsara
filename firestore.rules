/**
 * Core Philosophy:
 * This ruleset implements a hybrid security model tailored for a lottery application.
 * It combines strict user-ownership for personal data (orders, tickets), role-based
 * access control for administrative functions (managing lotteries), and public read
 * access for shared data (active lotteries).
 *
 * Data Structure:
 * User-specific data (orders, tickets) are stored in subcollections under `/users/{userId}`.
 * This path-based ownership allows for simple and secure rules. A dedicated `/roles_admin` 
 * collection serves as an efficient, non-hierarchical lookup table for identifying administrators.
 *
 * Key Security Decisions:
 * 1. Admin Checks: Administrator privileges are verified using an `exists()` check against
 *    the `/roles_admin/{userId}` collection. This is significantly more performant
 *    and secure than reading a 'role' field from a user profile.
 * 2. Path-Based Security for Reads: For user-specific data in subcollections
 *    (e.g., `/users/{userId}/orders`), rules can simply check if the requester's UID
 *    matches the `{userId}` in the path, ensuring users can only access their own data.
 * 3. Collection Group Queries: Rules are in place to allow administrators to perform
 *    collection group queries across all `orders` and `tickets` for administrative
 *    purposes (e.g., viewing all orders, drawing a lottery winner).
 * 4. Write Operations: All write operations (`create`, `update`, `delete`) are
 *    strictly controlled. Users can create their own orders, but only admins can
 *    confirm them (update status) or create tickets.
 * 5. Listing Prohibition: Listing all users from the `/users` collection is explicitly
 *    disallowed to protect user privacy and prevent data scraping.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper Functions
    // -------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    function isCreatingOwnContent(userId) {
      return request.resource.data.userId == userId;
    }
    
    function isUserIdImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }
    
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false; // Disallow listing all users to protect privacy.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) || isAdmin();

      match /orders/{orderId} {
        // Owner can create and read their own orders.
        // Admins can read any order.
        allow read, create: if isOwner(userId) || isAdmin();
        // Only admins can update an order's status (e.g., 'paid') or delete it.
        allow update, delete: if isAdmin();
      }

      match /tickets/{ticketId} {
        // Owner can read their own tickets. Admins can read any ticket.
        allow read: if isOwner(userId) || isAdmin();
        // Tickets are only ever created by an admin function (confirming an order).
        // Clients cannot create, update, or delete tickets directly.
        allow write: if isAdmin();
      }
    }

    // This collection group query is used by admins to list all orders.
    match /{path=**}/orders/{orderId} {
      allow list: if isAdmin();
    }
    
    // This collection group query is used by admins to draw a winner from all tickets for a lottery.
    match /{path=**}/tickets/{ticketId} {
      allow list: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read, write: if false; // Must be managed by a trusted server process.
    }

    match /lotteries/{lotteryId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /payments/{paymentId} {
      // NOTE: The 'userId' field MUST be denormalized onto this document for these rules to work.
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isAdmin(); // For now, only admins can list payments.
      allow create: if isOwner(request.resource.data.userId); // Assumes a client (or function) can create a payment record for themselves.
      allow update: if (isOwner(resource.data.userId) || isAdmin()) && isUserIdImmutable();
      allow delete: if false; // Payments should generally not be deletable by clients.
    }
  }
}
